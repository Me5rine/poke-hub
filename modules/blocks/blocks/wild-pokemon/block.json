{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "pokehub/wild-pokemon",
	"title": "Wild Pokémon",
	"category": "pokehub",
	"icon": "pets",
	"description": "Displays the list of Pokémon available in the wild with their images, shiny and regional status.",
	"keywords": ["pokemon", "wild", "nature", "shiny", "regional", "pokehub"],
	"textdomain": "poke-hub",
	"supports": {
		"html": false,
		"align": false
	},
	"attributes": {
		"autoDetect": {
			"type": "boolean",
			"default": true
		},
		"pokemonIds": {
			"type": "array",
			"default": []
		},
		"rarePokemonIds": {
			"type": "array",
			"default": []
		},
		"forcedShinyIds": {
			"type": "array",
			"default": []
		},
		"showRareSection": {
			"type": "boolean",
			"default": true
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}




