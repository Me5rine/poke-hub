{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "pokehub/go-pass",
	"title": "Pass GO",
	"category": "pokehub",
	"icon": "chart-bar",
	"description": "Affiche un Pass GO (résumé ou grille complète) à partir d’un événement spécial Pass GO.",
	"keywords": ["go pass", "battle pass", "pokehub", "event"],
	"textdomain": "poke-hub",
	"supports": {
		"html": false,
		"align": false
	},
	"attributes": {
		"specialEventId": {
			"type": "number",
			"default": 0
		},
		"displayMode": {
			"type": "string",
			"default": "summary"
		},
		"hostKind": {
			"type": "string",
			"default": ""
		},
		"hostId": {
			"type": "number",
			"default": 0
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
