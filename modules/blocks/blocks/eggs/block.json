{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "pokehub/eggs",
  "title": "Pokémon Eggs",
  "category": "pokehub",
  "icon": "admin-page",
  "description": "Displays eggs (types, icons) and the list of Pokémon by type with rarity, shiny, regional and min/max CP.",
  "keywords": ["egg", "hatch", "pokehub", "pokemon"],
  "textdomain": "poke-hub",
  "supports": { "html": false, "align": false },
  "attributes": {
    "source": { "type": "string", "default": "post" },
    "poolId": { "type": "number", "default": 0 },
    "title": { "type": "string", "default": "" }
  },
  "editorScript": "file:./index.js",
  "render": "file:./render.php"
}
