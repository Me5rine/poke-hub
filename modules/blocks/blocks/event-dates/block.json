{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 2,
	"name": "pokehub/event-dates",
	"title": "Event Dates",
	"category": "pokehub",
	"icon": "calendar-alt",
	"description": "Displays the start and end dates of an event with visual indicators (green/red lights).",
	"keywords": ["dates", "event", "pokehub"],
	"textdomain": "poke-hub",
	"supports": {
		"html": false,
		"align": false
	},
	"attributes": {
		"autoDetect": {
			"type": "boolean",
			"default": true
		},
		"startDate": {
			"type": "string",
			"default": ""
		},
		"endDate": {
			"type": "string",
			"default": ""
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php",
	"script": false,
	"style": false
}

